{
  "name": "advents",
  "scripts": {
    "dev": "pnpm --dir apps/web run dev",
    "web": "pnpm --dir apps/web",
    "common": "pnpm --dir packages/common",
    "db": "pnpm --dir packages/db",
    "engine": "pnpm --dir packages/engine",
    "eslint-config": "pnpm --dir packages/eslint-config",
    "mutations": "pnpm --dir packages/mutations",
    "queries": "pnpm --dir packages/queries",
    "supabase": "pnpm --dir packages/supabase",
    "typescript-config": "pnpm --dir packages/typescript-config",
    "doc": "pnpm --dir modules/docs",
    "sdk": "pnpm --dir modules/advents-react-native",
    "lint": "eslint . --fix --ignore-pattern modules/advents-react-native && prettier . \"!modules/advents-react-native\" --write && pnpm run sdk lint",
    "clear": "./scripts/clear.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "typescript": "~5.4.5"
  },
  "eslintConfig": {
    "extends": [
      "./packages/eslint-config/node.js"
    ]
  },
  "prettier": "./packages/eslint-config/prettier.config.js"
}
