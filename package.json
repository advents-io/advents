{
  "name": "advents",
  "scripts": {
    "dev": "pnpm --dir apps/app run dev",
    "app": "pnpm --dir apps/app",
    "common": "pnpm --dir packages/common",
    "db": "pnpm --dir packages/db",
    "engine": "pnpm --dir packages/engine",
    "eslint-config": "pnpm --dir packages/eslint-config",
    "mutations": "pnpm --dir packages/mutations",
    "queries": "pnpm --dir packages/queries",
    "supabase": "pnpm --dir packages/supabase",
    "typescript-config": "pnpm --dir packages/typescript-config",
    "doc": "pnpm --dir modules/docs",
    "sdk": "pnpm --dir modules/advents-react-native",
