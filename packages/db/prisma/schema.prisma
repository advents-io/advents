generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id String @id @default(uuid())

  title        String?
  domain       String
  slug         String
  androidUrl   String  @map("android_url")
  iosUrl       String  @map("ios_url")
  fallbackUrl  String  @map("fallback_url")
  clickCount   Int     @default(0) @map("click_count")
  installCount Int     @default(0) @map("install_count")

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  clicks Click[]

  @@unique([domain, slug])
  @@map("links")
}

model App {
  id String @id @default(uuid())

  name               String
  slug               String
  defaultDomain      String  @map("default_domain")
  imageUrl           String  @map("image_url")
  androidUrl         String  @map("android_url")
  iosUrl             String  @map("ios_url")
  defaultFallbackUrl String? @map("default_fallback_url")
  qrcodeLogoUrl      String? @map("qrcode_logo_url")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  links    Link[]
  sessions Session[]
  apiKeys  ApiKey[]

  @@unique([slug, teamId])
  @@map("apps")
}

model Team {
  id String @id @default(uuid())

  name String
  slug String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members Member[]
  apps    App[]

  @@map("teams")
}

model Member {
  id String @id @default(uuid())

  userId String @unique @map("user_id")
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("members")
}

model ApiKey {
  id String @id @default(uuid())

  key String @unique

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("api_keys")
}

model Click {
  id String @id

  destinationUrl String  @map("destination_url")
  os             String?

  referer    String
  refererUrl String @map("referer_url")

  // Request device data
  userAgent       String? @map("user_agent")
  deviceBrand     String? @map("device_brand")
  deviceModel     String? @map("device_model")
  deviceType      String? @map("device_type")
  osVersion       String? @map("os_version")
  browser         String?
  browserVersion  String? @map("browser_version")
  engine          String?
  engineVersion   String? @map("engine_version")
  cpuArchitecture String? @map("cpu_architecture")
  isBot           Boolean @map("is_bot")

  // Request geo data
  ip        String?
  continent String?
  country   String?
  city      String?
  region    String?
  latitude  String?
  longitude String?

  linkId String @map("link_id")
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  attribution Attribution?

  @@map("clicks")
}

model Session {
  id String @id @default(uuid())

  sdkName    String?   @map("sdk_name")
  sdkVersion String?   @map("sdk_version")
  framework  String?
  deviceTime DateTime? @map("device_time")
  os         String?
  package    String?

  androidAaid            String? @map("android_aaid")
  androidId              String? @map("android_id")
  androidInstallReferrer String? @map("android_install_referrer")

  iosIdfv                String? @map("ios_idfv")
  iosIdfa                String? @map("ios_idfa")
  iosAttPermissionStatus String? @map("ios_att_permission_status")
  iosClipboardClickId    String? @map("ios_clipboard_click_id")
  iosDeviceModelId       String? @map("ios_device_model_id")

  installTime DateTime? @map("install_time")

  // Device data
  userAgent       String? @map("user_agent")
  deviceName      String? @map("device_name")
  deviceBrand     String? @map("device_brand")
  deviceModel     String? @map("device_model")
  deviceType      String? @map("device_type")
  deviceYearClass String? @map("device_year_class")
  osVersion       String? @map("os_version")
  osBuildId       String? @map("os_build_id")
  appVersion      String? @map("app_version")

  // Request geo data
  ip        String?
  continent String?
  country   String?
  city      String?
  region    String?
  latitude  String?
  longitude String?

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  attribution Attribution?

  @@map("sessions")
}

enum AttributionMethod {
  android_deterministic_referrer
  android_probabilistic
  ios_deterministic_click
  ios_probabilistic
}

model Attribution {
  id String @id @default(uuid())

  method AttributionMethod

  sessionId String  @unique @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clickId String @unique @map("click_id")
  click   Click  @relation(fields: [clickId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("attributions")
}
