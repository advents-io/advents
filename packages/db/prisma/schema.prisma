generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  title                 String? @db.VarChar(64)
  domain                String
  slug                  String  @db.VarChar(20)
  androidUrl            String  @map("android_url")
  iosUrl                String  @map("ios_url")
  disableIosPreviewPage Boolean @default(false) @map("disable_ios_preview_page")
  fallbackUrl           String  @map("fallback_url")
  campaignCost          Float?  @map("campaign_cost")

  clickCount   Int   @default(0) @map("click_count")
  installCount Int   @default(0) @map("install_count")
  revenueCount Float @default(0) @map("revenue_count")

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  clicks       Click[]
  attributions Attribution[]
  purchases    Purchase[]

  @@unique([domain, slug])
  @@map("links")
}

model App {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  name                         String  @db.VarChar(64)
  slug                         String  @db.VarChar(48)
  defaultDomain                String  @map("default_domain")
  imageUrl                     String  @map("image_url")
  androidUrl                   String  @map("android_url")
  iosUrl                       String  @map("ios_url")
  defaultDisableIosPreviewPage Boolean @default(false) @map("default_disable_ios_preview_page")
  defaultFallbackUrl           String? @map("default_fallback_url")
  qrCodeLogoUrl                String? @map("qrcode_logo_url")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  links        Link[]
  sessions     Session[]
  apiKeys      ApiKey[]
  clicks       Click[]
  attributions Attribution[]
  purchases    Purchase[]
  devices      Device[]

  @@unique([slug, teamId])
  @@map("apps")
}

model Team {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  name String @db.VarChar(64)
  slug String @unique @db.VarChar(48)

  members Member[]
  apps    App[]

  @@map("teams")
}

model Member {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  userId String @unique @map("user_id")
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  @@map("members")
}

model ApiKey {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  key String @unique

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Click {
  id        String   @id
  createdAt DateTime @default(now()) @map("created_at")

  destinationUrl String  @map("destination_url")
  os             String?

  referer    String
  refererUrl String @map("referer_url")

  userAgent       String? @map("user_agent")
  deviceBrand     String? @map("device_brand")
  deviceModel     String? @map("device_model")
  deviceType      String? @map("device_type")
  osVersion       String? @map("os_version")
  browser         String?
  browserVersion  String? @map("browser_version")
  engine          String?
  engineVersion   String? @map("engine_version")
  cpuArchitecture String? @map("cpu_architecture")
  isBot           Boolean @map("is_bot")

  ip        String?
  continent String?
  country   String?
  city      String?
  region    String?
  latitude  String?
  longitude String?

  linkId String @map("link_id")
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  attribution Attribution?

  @@map("clicks")
}

enum DeviceOs {
  android
  ios

  @@map("device_os")
}

model Device {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  os DeviceOs

  androidAaid String? @map("android_aaid") // Android Advertising ID
  androidId   String? @map("android_id") // Android ID

  iosIdfv String? @map("ios_idfv") // Identifier for Vendor
  iosIdfa String? @map("ios_idfa") // Identifier for Advertiser

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  sessions     Session[]
  attributions Attribution[]
  purchases    Purchase[]

  @@unique([appId, androidAaid])
  @@unique([appId, androidId])
  @@unique([appId, iosIdfv])
  @@unique([appId, iosIdfa])
  @@map("devices")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  sdkName        String   @map("sdk_name")
  sdkVersion     String   @map("sdk_version")
  framework      String
  deviceTime     DateTime @map("device_time")
  os             DeviceOs
  package        String
  isFirstSession Boolean  @map("is_first_session") // Will be the first session after install or after clearing app local data
  isReinstall    Boolean  @map("is_reinstall") // If user cleared app local data or reinstalled the app, we need to send the persisted device id to update device storage

  androidInstallReferrer String? @map("android_install_referrer")

  iosAttPermissionStatus String? @map("ios_att_permission_status")
  iosClipboardClickId    String? @map("ios_clipboard_click_id") // Clipboard will be read only in the first session and if user granted permission
  iosDeviceModelId       String? @map("ios_device_model_id")

  installTime DateTime? @map("install_time")

  userAgent   String? @map("user_agent")
  deviceName  String? @map("device_name")
  deviceBrand String? @map("device_brand")
  deviceModel String? @map("device_model")
  deviceType  String? @map("device_type")
  osVersion   String? @map("os_version")
  osBuildId   String? @map("os_build_id")
  appVersion  String? @map("app_version")

  ip        String?
  continent String?
  country   String?
  city      String?
  region    String?
  latitude  String?
  longitude String?

  deviceId String @map("device_id")
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  attribution Attribution?
  purchases   Purchase[]

  @@map("sessions")
}

enum AttributionMethod {
  android_deterministic_referrer
  android_probabilistic
  ios_deterministic_click
  ios_probabilistic

  @@map("attribution_method")
}

model Attribution {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  method AttributionMethod

  sessionId String  @unique @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clickId String @unique @map("click_id")
  click   Click  @relation(fields: [clickId], references: [id], onDelete: Cascade)

  linkId String @map("link_id")
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  deviceId String @map("device_id")
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("attributions")
}

model Purchase {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  value Float

  sessionId String  @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  linkId String? @map("link_id")
  link   Link?   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  deviceId String @map("device_id")
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("purchases")
}
