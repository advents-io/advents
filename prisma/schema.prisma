generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id String @id @default(uuid())

  title       String?
  domain      String
  slug        String
  androidUrl  String  @map("android_url")
  iosUrl      String  @map("ios_url")
  fallbackUrl String  @map("fallback_url")
  clicks      Int     @default(0)
  installs    Int     @default(0)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  clicksArray Click[]

  @@unique([domain, slug])
  @@map("links")
}

model App {
  id String @id @default(uuid())

  name               String
  slug               String
  defaultDomain      String  @map("default_domain")
  imageUrl           String  @map("image_url")
  androidUrl         String  @map("android_url")
  iosUrl             String  @map("ios_url")
  defaultFallbackUrl String? @map("default_fallback_url")
  qrcodeLogoUrl      String? @map("qrcode_logo_url")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  links    Link[]
  sessions Session[]
  apiKeys  ApiKey[]

  @@unique([slug, teamId])
  @@map("apps")
}

model Team {
  id String @id @default(uuid())

  name String
  slug String @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members Member[]
  apps    App[]

  @@map("teams")
}

model Member {
  id String @id @default(uuid())

  userId String @unique @map("user_id")
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("members")
}

model ApiKey {
  id String @id @default(uuid())

  key String @unique

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("api_keys")
}

model Click {
  id String @id

  destinationUrl String @map("destination_url")
  os             String

  referer    String
  refererUrl String @map("referer_url")

  // Request Device data
  deviceType      String  @map("device_type")
  deviceBrand     String  @map("device_brand")
  deviceModel     String  @map("device_model")
  osVersion       String  @map("os_version")
  userAgent       String  @map("user_agent")
  browser         String
  browserVersion  String  @map("browser_version")
  engine          String
  engineVersion   String  @map("engine_version")
  cpuArchitecture String  @map("cpu_architecture")
  isBot           Boolean @map("is_bot")

  // Request Location data
  ip        String
  continent String
  country   String
  city      String
  region    String
  latitude  String
  longitude String

  linkId String @map("link_id")
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  installs Install[]

  @@map("clicks")
}

// TODO: add framework info (version, name)
model Session {
  id String @id @default(uuid())

  sdkName         String   @map("sdk_name")
  sdkVersion      String   @map("sdk_version")
  deviceTimestamp DateTime @map("device_timestamp")
  os              String

  androidId              String?   @map("android_id")
  androidInstallReferrer String?   @map("android_install_referrer")
  installTime            DateTime? @map("install_time")

  // Device data
  deviceName      String? @map("device_name")
  deviceBrand     String? @map("device_brand")
  deviceModel     String? @map("device_model")
  deviceYearClass String? @map("device_year_class")
  osVersion       String? @map("os_version")
  appVersion      String? @map("app_version")

  // Request Device data
  userAgent String @map("user_agent")

  // Request Location data
  ip        String
  continent String
  country   String
  city      String
  region    String
  latitude  String
  longitude String

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  installs Install[]

  @@map("sessions")
}

model Install {
  id String @id @default(uuid())

  sessionId String  @unique @map("session_id")
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  clickId String @unique @map("click_id")
  click   Click  @relation(fields: [clickId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("installs")
}

model Event {
  id String @id @default(uuid())

  data Json

  createdAt DateTime @default(now()) @map("created_at")

  @@map("events")
}
