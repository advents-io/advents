generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id String @id @default(uuid())

  title       String?
  domain      String
  slug        String
  androidUrl  String  @map("android_url")
  iosUrl      String  @map("ios_url")
  fallbackUrl String  @map("fallback_url")
  clicks      Int     @default(0)
  installs    Int     @default(0)

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  clicksArray Click[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  @@unique([domain, slug])
  @@map("links")
}

model App {
  id String @id @default(uuid())

  name               String
  slug               String
  defaultDomain      String  @map("default_domain")
  imageUrl           String  @map("image_url")
  androidUrl         String  @map("android_url")
  iosUrl             String  @map("ios_url")
  defaultFallbackUrl String? @map("default_fallback_url")
  qrcodeLogoUrl      String? @map("qrcode_logo_url")

  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  links   Link[]
  apiKeys ApiKey[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String   @map("created_by")
  updatedBy String   @map("updated_by")

  @@unique([slug, teamId])
  @@map("apps")
}

model Team {
  id String @id @default(uuid())

  name String
  slug String @unique

  members Member[]
  apps    App[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model Member {
  id String @id @default(uuid())

  userId String @unique @map("user_id")
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("members")
}

model ApiKey {
  id String @id @default(uuid())

  key String @unique

  appId String @map("app_id")
  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("api_keys")
}

model Click {
  // Gerado pelo Postgres devido a eu criar o Click pela api do Supabase
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  linkId String @map("link_id")
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  identityHash    String  @map("identity_hash")
  destinationUrl  String  @map("destination_url")
  referer         String
  refererUrl      String  @map("referer_url")
  ip              String
  continent       String
  country         String
  city            String
  region          String
  latitude        String
  longitude       String
  device          String
  deviceVendor    String  @map("device_vendor")
  deviceModel     String  @map("device_model")
  browser         String
  browserVersion  String  @map("browser_version")
  engine          String
  engineVersion   String  @map("engine_version")
  os              String
  osVersion       String  @map("os_version")
  cpuArchitecture String  @map("cpu_architecture")
  userAgent       String  @map("user_agent")
  isBot           Boolean @map("is_bot")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("clicks")
}

model Session {
  id String @id @default(uuid())

  sdkName    String @map("sdk_name")
  sdkVersion String @map("sdk_version")
  os         String

  androidId              String?   @map("android_id")
  androidInstallReferrer String?   @map("android_install_referrer")
  androidInstallTime     DateTime? @map("android_install_time")
  userAgent              String?   @map("user_agent")
  deviceName             String?   @map("device_name")
  deviceBrand            String?   @map("device_brand")
  deviceModel            String?   @map("device_model")
  deviceYearClass        String?   @map("device_year_class")
  osVersion              String?   @map("os_version")
  appVersion             String?   @map("app_version")
  timestamp              DateTime

  createdAt DateTime @default(now()) @map("created_at")

  @@map("sessions")
}

model Event {
  id String @id @default(uuid())

  data Json

  createdAt DateTime @default(now()) @map("created_at")

  @@map("events")
}
