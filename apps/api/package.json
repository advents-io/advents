{
  "name": "@advents/api",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "migrate": "prisma migrate dev && prisma generate",
    "migrate:prod": "prisma migrate deploy && prisma generate",
    "build": "tsup src",
    "start": "node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.15.0",
    "fastify": "^4.27.0",
    "fastify-type-provider-zod": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@advents/tsconfig": "workspace:*",
    "@advents/eslint-config": "workspace:*",
    "prisma": "^5.15.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.2"
  },
  "eslintConfig": {
    "extends": [
      "@advents/eslint-config/node.js"
    ]
  },
  "prettier": "@advents/eslint-config/prettier.config.js"
}
